BINANCE_API_KEY=replace_me
BINANCE_API_SECRET=replace_me
BINANCE_FAPI_BASE_URL=https://fapi.binance.com
BINANCE_POSITION_MODE=ONE_WAY

# 실주문은 두 값을 모두 true로 설정해야만 나갑니다.
BINANCE_LIVE_TRADING=false
BINANCE_ENABLE_ORDERS=false

# engine.medicalnewshub.info 터널이 바라볼 로컬 상태 API
ENGINE_HOST=127.0.0.1
ENGINE_PORT=8788
ENGINE_CORS_ORIGIN=*

# 손실률 계산 기준값. 비워두면 현재 equity를 기준으로 봅니다.
DAY_START_EQUITY=
WEEK_START_EQUITY=
MONTH_START_EQUITY=

# 키 없이 로컬 UI만 볼 때 쓰는 fallback 값
FALLBACK_EQUITY=1000
FALLBACK_WALLET_BALANCE=1000

# Market Internal Engine
# CoinGecko public endpoint can work without a key, but a demo/pro key improves reliability.
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
MARKET_INTERNALS_CACHE_SECONDS=300
MARKET_INTERNALS_UNIVERSE_LIMIT=200
MARKET_INTERNALS_BREADTH_LIMIT=100
MARKET_INTERNALS_BREADTH_WORKERS=8
MARKET_INTERNALS_DISABLE_VOLUME_BREADTH=false
