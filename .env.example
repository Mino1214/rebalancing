BINANCE_API_KEY=replace_me
BINANCE_API_SECRET=replace_me
BINANCE_FAPI_BASE_URL=https://fapi.binance.com
BINANCE_POSITION_MODE=ONE_WAY

# 실주문은 두 값을 모두 true로 설정해야만 나갑니다.
BINANCE_LIVE_TRADING=false
BINANCE_ENABLE_ORDERS=false

# engine.medicalnewshub.info 터널이 바라볼 로컬 상태 API
ENGINE_HOST=127.0.0.1
ENGINE_PORT=8788
ENGINE_CORS_ORIGIN=*
ENGINE_WEBHOOK_TOKEN=
ENGINE_WEBHOOK_TOKEN_FILE=.state/engine_webhook_token
ENGINE_SIGNAL_STORE_PATH=.state/tradingview_alerts.json
ENGINE_SIGNAL_STORE_MAX_RECORDS=200
ENGINE_STATUS_ALERT_EVENT_LIMIT=200
ENGINE_TV_MAX_ALERT_AGE_SECONDS=0

# Paper trading simulation. This does not send real Binance orders.
PAPER_TRADING_ENABLED=true
PAPER_INITIAL_EQUITY=1000
PAPER_STATE_PATH=.state/paper_trading.json
PAPER_MAX_LEVERAGE=2
PAPER_MIN_ORDER_NOTIONAL=10
PAPER_MIN_REBALANCE_MINUTES=60
PAPER_BLOCK_NEW_ENTRIES_LOSS_PCT=-0.02
PAPER_FEE_RATE=0.0004
PAPER_SLIPPAGE_BPS=0
PAPER_TRADE_HISTORY_LIMIT=500

# 손실률 계산 기준값. 비워두면 현재 equity를 기준으로 봅니다.
DAY_START_EQUITY=
WEEK_START_EQUITY=
MONTH_START_EQUITY=

# 키 없이 로컬 UI만 볼 때 쓰는 fallback 값
FALLBACK_EQUITY=1000
FALLBACK_WALLET_BALANCE=1000

# Market Internal Engine
# CoinGecko public endpoint can work without a key, but a demo/pro key improves reliability.
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
MARKET_INTERNALS_CACHE_SECONDS=300
MARKET_INTERNALS_UNIVERSE_LIMIT=200
MARKET_INTERNALS_BREADTH_LIMIT=100
MARKET_INTERNALS_BREADTH_WORKERS=8
MARKET_INTERNALS_DISABLE_VOLUME_BREADTH=false

# Optional PostgreSQL parallel record layer for self-learning.
# Existing JSON files remain the source of local fallback state.
# Use DATABASE_URL or the standard PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD env vars.
DATABASE_URL=
